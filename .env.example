# Where to POST each incoming user message. Points at your tadry-web /api/bot.
TADRY_API_URL=https://www.your-tadry-domain.com/api/bot

# Shared secret. Also set the same value as BOT_SHARED_SECRET in your
# tadry-web Vercel env vars. If unset here, the bot won't authenticate
# and the endpoint will reject its requests.
BOT_SHARED_SECRET=

# Where to store the WhatsApp session files. On Railway, mount a
# persistent volume at /data/auth_info and set this to /data/auth_info
# so re-deploys don't lose the pairing (otherwise you'll have to
# re-scan the QR every time the bot restarts).
AUTH_DIR=./auth_info

# Log verbosity: debug, info (default), warn, error
LOG_LEVEL=info
